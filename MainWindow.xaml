<Window x:Class="ChromeUpdaterWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chrome 便携版智能升级器" Height="500" Width="750"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Microsoft YaHei" FontSize="14" Opacity="0.95"
        Icon="logo.ico">

    <!-- 极美圆角带阴影外框 -->
    <Border Background="#F2F4F6" CornerRadius="12" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <!-- 顶部拖拽标题栏 -->
            <Grid Height="40" VerticalAlignment="Top" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Image Source="/logo.ico" Height="28" Width="28" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock Text="Chrome 便携版智能升级器" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button Content="—" Width="30" Height="30" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" Foreground="#7F8C8D" Click="BtnMinimize_Click" Cursor="Hand"/>
                    <Button Content="✕" Width="30" Height="30" Background="Transparent" BorderThickness="0" FontSize="16" FontWeight="Bold" Foreground="#7F8C8D" Click="BtnClose_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- 核心参数区域 -->
            <StackPanel Margin="30,60,30,30">
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="系统架构" Foreground="#7F8C8D" Margin="5,0,0,5"/>
                        <Border x:Name="borderOS" Background="White" BorderBrush="#D6DBDF" BorderThickness="1" CornerRadius="4" Padding="15,12">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rdo64" Content="64位 (自动检测)" GroupName="OS" Margin="0,0,20,0" IsChecked="True"/>
                                <RadioButton x:Name="rdo32" Content="32位" GroupName="OS"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="是否设为默认浏览器" Foreground="#7F8C8D" Margin="5,20,0,5"/>
                        <Border x:Name="borderDefault" Background="White" BorderBrush="#D6DBDF" BorderThickness="1" CornerRadius="4" Padding="15,12">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rdoDefaultYes" Content="设为默认浏览器" GroupName="Def" Margin="0,0,20,0" IsChecked="True" Click="RdoDefault_Click"/>
                                <RadioButton x:Name="rdoDefaultNo" Content="否" GroupName="Def" Click="RdoDefault_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <TextBlock Text="版本类型" Foreground="#7F8C8D" Margin="5,0,0,5"/>
                        <Border x:Name="borderChannel" Background="White" BorderBrush="#D6DBDF" BorderThickness="1" CornerRadius="4">
                            <ComboBox x:Name="cmbChannel" SelectedIndex="0" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderThickness="0" SelectionChanged="CmbChannel_SelectionChanged">
                                <ComboBoxItem Content="稳定版 (Stable)--绝大多数用户的选择"/>
                                <ComboBoxItem Content="测试版 (Beta)--比稳定版早一个版本"/>
                                <ComboBoxItem Content="开发版 (Dev)--每周更新，面向开发者"/>
                                <ComboBoxItem Content="金丝雀版 (Canary)--每天更新，最新最前沿"/>
                            </ComboBox>
                        </Border>

                        <TextBlock Text="是否创建桌面快捷方式" Foreground="#7F8C8D" Margin="5,21,0,5"/>
                        <Border x:Name="borderShortcut" Background="White" BorderBrush="#D6DBDF" BorderThickness="1" CornerRadius="4" Padding="15,12">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rdoShortcutYes" Content="创建桌面快捷方式" GroupName="Short" Margin="0,0,20,0" IsChecked="True" Click="RdoShortcut_Click"/>
                                <RadioButton x:Name="rdoShortcutNo" Content="否" GroupName="Short" Click="RdoShortcut_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="lblStatus" Text="本地环境检测中..." HorizontalAlignment="Center" Margin="0,15" Foreground="#34495E" FontSize="13" FontWeight="Bold"/>

                <Grid Margin="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnLaunch" Grid.Column="0" Content="启动浏览器" Margin="0,0,5,0" Height="45" Background="#2ECC71" Foreground="White" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnLaunch_Click"/>
                    <Button x:Name="btnUpdate" Grid.Column="1" Content="检查并更新" Margin="5,0,5,0" Height="45" Background="#3498DB" Foreground="White" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnUpdate_Click"/>
                    <Button x:Name="btnAICheck" Grid.Column="2" Content="AI 模型体检" Margin="5,0,5,0" Height="45" Background="#95A5A6" Foreground="White" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnAICheck_Click"/>
                    <Button x:Name="btnExit"   Grid.Column="3" Content="退出程序" Margin="5,0,0,0" Height="45" Background="#E74C3C" Foreground="White" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click"/>
                </Grid>

                <!-- 🌟 升级后的底部两行排版：技术支持 + 动态版本自更新提示 -->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,15,0,0">

                    <!-- 第一行：技术支持与社交图标 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="技术支持: " Foreground="#95A5A6" VerticalAlignment="Center"/>

                        <!-- 微信 -->
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Margin="6,0,0,0" VerticalAlignment="Center" Cursor="Hand" Click="WeChat_Click" ToolTip="微信：jiujiujiayi666 (点击可直接复制)">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="16" Height="16">
                                    <Path Fill="#95A5A6" Data="M11.176 14.429c-2.665 0-4.826-1.8-4.826-4.018 0-2.22 2.159-4.02 4.824-4.02S16 8.191 16 10.411c0 1.21-.65 2.301-1.666 3.036a.324.324 0 0 0-.12.366l.218.81a.616.616 0 0 1 .029.117.166.166 0 0 1-.162.162.177.177 0 0 1-.092-.03l-1.057-.61a.519.519 0 0 0-.256-.074.509.509 0 0 0-.142.021 5.668 5.668 0 0 1-1.576.22ZM9.064 9.542a.647.647 0 1 0 .557-1 .645.645 0 0 0-.646.647.615.615 0 0 0 .09.353Zm3.232.001a.646.646 0 1 0 .546-1 .645.645 0 0 0-.644.644.627.627 0 0 0 .098.356Z M0 6.826c0 1.455.781 2.765 2.001 3.656a.385.385 0 0 1 .143.439l-.161.6-.1.373a.499.499 0 0 0-.032.14.192.192 0 0 0 .193.193c.039 0 .077-.01.111-.029l1.268-.733a.622.622 0 0 1 .308-.088c.058 0 .116.009.171.025a6.83 6.83 0 0 0 1.625.26 4.45 4.45 0 0 1-.177-1.251c0-2.936 2.785-5.02 5.824-5.02.05 0 .1 0 .15.002C10.587 3.429 8.392 2 5.796 2 2.596 2 0 4.16 0 6.826m4.632-1.555a.77.77 0 1 1-1.54 0 .77.77 0 0 1 1.54 0Zm3.875 0a.77.77 0 1 1-1.54 0 .77.77 0 0 1 1.54 0Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- Telegram -->
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Margin="10,0,0,0" VerticalAlignment="Center" Cursor="Hand" Click="Telegram_Click" ToolTip="Telegram：@YuC2027">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="16" Height="16">
                                    <Path Fill="#95A5A6" Data="M 16 8 A 8 8 0 1 1 0 8 a 8 8 0 0 1 16 0 z M 8.287 5.906 c -0.778 0.324 -2.334 0.994 -4.666 2.01 c -0.378 0.15 -0.577 0.298 -0.595 0.442 c -0.03 0.243 0.275 0.339 0.69 0.47 l 0.175 0.055 c 0.408 0.133 0.958 0.288 1.243 0.294 c 0.26 0.006 0.549 -0.1 0.868 -0.32 c 2.179 -1.471 3.304 -2.214 3.374 -2.23 c 0.05 -0.012 0.12 -0.026 0.166 0.016 c 0.047 0.041 0.042 0.12 0.037 0.141 c -0.03 0.129 -1.227 1.241 -1.846 1.817 c -0.193 0.18 -0.33 0.307 -0.358 0.336 a 8.154 8.154 0 0 1 -0.188 0.186 c -0.38 0.366 -0.664 0.64 0.015 1.088 c 0.327 0.216 0.589 0.393 0.85 0.571 c 0.284 0.194 0.568 0.387 0.936 0.629 c 0.093 0.06 0.183 0.125 0.27 0.187 c 0.331 0.236 0.63 0.448 0.997 0.414 c 0.214 -0.02 0.435 -0.22 0.547 -0.82 c 0.265 -1.417 0.786 -4.486 0.906 -5.751 a 1.426 1.426 0 0 0 -0.013 -0.315 a 0.337 0.337 0 0 0 -0.114 -0.217 a 0.526 0.526 0 0 0 -0.31 -0.093 c -0.3 0.005 -0.763 0.166 -2.984 1.09 z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- GitHub -->
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Margin="10,0,0,0" VerticalAlignment="Center" Cursor="Hand" Click="Github_Click" ToolTip="访问 GitHub 开源项目">
                            <Viewbox Width="16" Height="16">
                                <Canvas Width="16" Height="16">
                                    <Path Fill="#95A5A6" Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <!-- 第二行：版本号 / 新版本动态升级按钮 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0" Height="25">

                        <!-- 正常状态下的版本号（无新版时显示） -->
                        <TextBlock x:Name="lblAppVersion" Text="当前升级器版本: 读取中..." Foreground="#95A5A6" VerticalAlignment="Center" Cursor="Arrow"/>

                        <!-- 发现新版时的闪动按钮（默认折叠） -->
                        <Button x:Name="btnAppUpdate" Content="🚀 发现新版本，点击立即自动升级！" Foreground="#E74C3C" FontWeight="Bold" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Visibility="Collapsed" Click="BtnAppUpdate_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <!-- 极客呼吸闪动效果 -->
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                    </StackPanel>

                </StackPanel>
            </StackPanel>

            <!-- 半透明遮罩层 -->
            <Grid x:Name="OverlayPanel" Visibility="Collapsed" Background="#F5F7F9FC">
                <Grid.RowDefinitions>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="180"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="550">
                    <TextBlock x:Name="lblOverlayStatus" Text="正在执行..." FontSize="18" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Border CornerRadius="8" ClipToBounds="True" Height="55" Background="#EAEDED">
                        <ProgressBar x:Name="progressBar" Minimum="0" Maximum="100" BorderThickness="0" Foreground="#2ECC71" Background="Transparent" PreviewMouseLeftButtonDown="ProgressBar_PreviewMouseDown"/>
                    </Border>
                </StackPanel>

                <!-- 彩蛋展示区 -->
                <Border Grid.Row="2" Height="180" ClipToBounds="True" Background="Transparent" HorizontalAlignment="Center" Width="710">
                    <Canvas>
                        <TextBlock x:Name="txtPoem" TextAlignment="Center" Width="710" FontSize="22" FontWeight="Bold" Canvas.Top="180">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00F2FE" Offset="0.0"/>
                                    <GradientStop Color="#4FACFE" Offset="0.5"/>
                                    <GradientStop Color="#00FF87" Offset="1.0"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00F2FE" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Canvas>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>